{
  "key": "company_passwords.passwordentry:list",
  "template": "list",
  "title": "Passwords",
  "version": "1",
  "data": {
    "source": "content_type",
    "content_type": "company_passwords.passwordentry",
    "method": "list",
    "params": {
      "page_size": 30,
      "ordering": "-modified_at"
    }
  },
  "node": {
    "kind": "list",
    "props": {
      "page_size": 30
    },
    "children": [
      {
        "kind": "card",
        "children": [
          {
            "kind": "field",
            "props": {
              "name": "name",
              "widget": "title"
            }
          },
          {
            "kind": "field",
            "props": {
              "name": "username",
              "widget": "subtitle"
            }
          }
        ],
        "on_tap": {
          "kind": "navigate",
          "screen": "company_passwords.passwordentry:detail",
          "params": {
            "pk": "$field(id)"
          }
        }
      }
    ]
  },
  "actions": []
}